# Jarvislabs API token — get yours at https://jarvislabs.ai/settings/api-keys
JL_API_KEY=

# Defaults applied when flags are omitted on `jltool instances create`
# (override any of these per-command with the matching CLI flag).
# Each variable maps 1:1 to a parameter on the SDK's instances.create().
JL_DEFAULT_GPU_TYPE=A100
JL_DEFAULT_NUM_GPUS=1
JL_DEFAULT_TEMPLATE=pytorch
JL_DEFAULT_STORAGE=40
JL_DEFAULT_NAME=
JL_DEFAULT_REGION=
JL_DEFAULT_DISK_TYPE=

# Optional: comma-separated HTTP ports to expose, e.g. "7860,8080"
JL_DEFAULT_HTTP_PORTS=

# Optional: default startup script id and filesystem id to attach
JL_DEFAULT_SCRIPT_ID=
JL_DEFAULT_SCRIPT_ARGS=
JL_DEFAULT_FS_ID=

# Optional: free-form arguments forwarded to the instance entrypoint
JL_DEFAULT_ARGUMENTS=
